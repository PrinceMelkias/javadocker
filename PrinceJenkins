pipeline {
    agent {
  label 'mylinux'
}

    stages {
        stage('Installing to Maven') {
            steps {
             sh 'sudo dnf install maven -y'
            }
        }
        stage('Clean package') {
            steps {
                sh 'sudo mvn clean package'
            }
        }
        stage('Artifacts') {
            steps {
                archiveArtifacts 'target/*.jar'
            }
        }
    }
}
